// vertexShader.glsl
uniform float uProgress; // 0.0 to 1.0 transition
uniform float uTime;
varying vec2 vUv;

attribute vec3 positionA; // Current state
attribute vec3 positionB; // AI-suggested target state

void main() {
  vUv = uv;
  
  // 1. Linear interpolation between two 3D states (the "4D" transition)
  vec3 morphedPosition = mix(positionA, positionB, uProgress);
  
  // 2. Add 'Synthetic Pulse' displacement based on AI status
  float pulse = sin(uTime * 2.0) * 0.1 * uProgress;
  morphedPosition += normal * pulse;

  vec4 modelPosition = modelMatrix * vec4(morphedPosition, 1.0);
  gl_Position = projectionMatrix * viewMatrix * modelPosition;
}
