export function usePresence(roomId: string) {
  const channel = supabase.channel(roomId);

  function join(user: any) {
    channel.subscribe();
    channel.track(user);
  }

  function onUpdate(callback: any) {
    channel.on("presence", { event: "sync" }, callback);
  }

  return { join, onUpdate };
}

