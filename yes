import { useEffect } from "react";
import { usePlayerStore } from "../engine/playerStore";

export function useMovement() {
  const setPosition = usePlayerStore((s: any) => s.setPosition);

  useEffect(() => {
    function handle(e: KeyboardEvent) {
      let move = [0, 0, 0];

      if (e.key === "w") move[2] -= 0.2;
      if (e.key === "s") move[2] += 0.2;
      if (e.key === "a") move[0] -= 0.2;
      if (e.key === "d") move[0] += 0.2;

      setPosition((prev: number[]) => [
        prev[0] + move[0],
        prev[1],
        prev[2] + move[2],
      ]);
    }

    window.addEventListener("keydown", handle);
    return () => window.removeEventListener("keydown", handle);
  }, []);
}

