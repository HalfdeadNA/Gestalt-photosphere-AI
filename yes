import { createContext, useContext, useState } from "react";

type EnvironmentState = "idle" | "forming" | "rendering" | "published";

type FieldState = {
  creator?: string;
  activeArtifact?: string;
  environment: EnvironmentState;
  energy: number;
  setEnvironment: (e: EnvironmentState) => void;
  setEnergy: (n: number) => void;
};

const FieldContext = createContext<FieldState | null>(null);

export function FieldProvider({ children }: { children: React.ReactNode }) {
  const [environment, setEnvironment] = useState<EnvironmentState>("idle");
  const [energy, setEnergy] = useState(40);

  return (
    <FieldContext.Provider
      value={{
        environment,
        energy,
        setEnvironment,
        setEnergy,
      }}
    >
      {children}
    </FieldContext.Provider>
  );
}

export function useField() {
  const ctx = useContext(FieldContext);
  if (!ctx) throw new Error("useField must be used inside FieldProvider");
  return ctx;
}

